# ExplorerOS-Mobile environment configuration
#
# Copy this file to `.env` and fill in the values from your Supabase project
# (Supabase Dashboard → Project Settings → API). The real `.env` is gitignored
# so keys are never committed.

SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=your-anon-or-publishable-key
